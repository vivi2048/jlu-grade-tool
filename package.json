{
  "name": "jlu-grade-tool",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run build:all",
    "build:all": "npm run build:sidepanel && npm run build:content && npm run build:background",
    "build:sidepanel": "cross-env BUILD_TARGET=sidepanel vite build",
    "build:content": "cross-env BUILD_TARGET=content vite build",
    "build:background": "cross-env BUILD_TARGET=background vite build",
    "package": "node scripts/package.js",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "cross-env": "^7.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
